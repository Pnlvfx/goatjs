{
  "name": "@goatjs/cli",
  "description": "Development CLI for testing and experimenting with GoatJS packages.",
  "private": true,
  "license": "MIT",
  "author": "Simone Gauli",
  "main": "dist/cli.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "apps/cli"
  },
  "scripts": {
    "unused": "node tools/unused.ts",
    "tsc": "tsc --noEmit",
    "lint": "eslint",
    "dev": "node --watch src/cli.ts",
    "build": "node tools/build.ts",
    "start": "node ."
  },
  "dependencies": {
    "@goatjs/cache": "workspace:*",
    "@goatjs/core": "workspace:*",
    "@goatjs/storage": "workspace:*"
  },
  "devDependencies": {
    "@goatjs/dbz": "workspace:*",
    "@goatjs/node-monorepo-eslint": "^2.0.0",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/ts-unused-exports": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
