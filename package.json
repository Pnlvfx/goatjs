{
  "name": "goatjs",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git"
  },
  "scripts": {
    "unused": "turbo unused",
    "tsc": "turbo tsc",
    "build": "turbo build",
    "dev": "yarn workspace @goatjs/cli dev",
    "lint": "turbo lint",
    "initialize": "yarn workspace @goatjs/node prettier-gen",
    "postinstall": "yarn initialize",
    "update": "yarn upgrade-interactive"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@goatjs/dbz": "workspace:*",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/yargs": "^17.0.35",
    "prettier": "^3.8.1",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "yargs": "^18.0.0"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
