{
  "name": "goatjs",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git"
  },
  "scripts": {
    "unused": "turbo unused",
    "tsc": "turbo tsc",
    "build": "turbo build",
    "dev": "yarn workspace @goatjs/cli dev",
    "lint": "turbo lint",
    "initialize": "yarn workspace @goatjs/node prettier-gen",
    "postinstall": "yarn initialize",
    "update": "yarn upgrade-interactive"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@goatjs/dbz": "workspace:*",
    "@goatjs/rimraf": "workspace:*",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
