    "directory": "packages/puppeteer-mouse"
  },
  "license": "MIT",
  "type": "module",
  "exports": "./src/mouse.ts",
  "publishConfig": {
    "exports": {
      "types": "./dist/mouse.d.ts",
      "import": "./dist/mouse.js",
      "require": "./dist/mouse.js"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit true",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
