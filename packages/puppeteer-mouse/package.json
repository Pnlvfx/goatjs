    "@goatjs/ts-unused-exports": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "execa": "^9.6.1",
    "puppeteer-core": "^24.43.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "puppeteer-core": "*"
  }
