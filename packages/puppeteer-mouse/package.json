{
  "name": "@goatjs/puppeteer-mouse",
  "description": "Visual mouse helper for Puppeteer that displays a visible cursor during automation.",
  "version": "1.61.0",
  "private": true,
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
