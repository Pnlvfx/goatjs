{
  "name": "@goatjs/download",
  "description": "A utility for downloading files from URLs with automatic filename detection.",
  "version": "2.6.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "packages/download"
  },
  "license": "MIT",
  "type": "module",
  "exports": "./src/download.ts",
  "publishConfig": {
    "exports": {
      "types": "./dist/download.d.ts",
      "import": "./dist/download.js",
      "require": "./dist/download.js"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "unused": "node tools/unused.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@goatjs/node": "workspace:*",
    "@goatjs/node-monorepo-eslint": "^2.14.0",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/ts-unused-exports": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@goatjs/node": "2.7.0"
  }
}
