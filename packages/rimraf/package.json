{
  "name": "@goatjs/rimraf",
  "description": "A cross-platform file and directory deletion utility (like rm -rf).",
  "version": "2.6.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "packages/rimraf"
  },
  "license": "MIT",
  "type": "module",
  "exports": "./src/rimraf.ts",
  "bin": "src/cli/rimraf.ts",
  "publishConfig": {
    "bin": "dist/cli/rimraf.js",
    "exports": {
      "types": "./dist/rimraf.d.ts",
      "import": "./dist/rimraf.js",
      "require": "./dist/rimraf.js"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit true",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "unused": "node tools/unused.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^2.19.0",
    "@goatjs/typescript-config": "workspace:*",
    "@types/node": "^25.7.0",
    "eslint": "^10.3.0",
    "execa": "^9.6.1",
    "typescript": "^6.0.3"
  }
}
