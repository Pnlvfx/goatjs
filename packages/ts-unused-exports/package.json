{
  "name": "@goatjs/ts-unused-exports",
  "description": "Find unused exports in TypeScript projects with support for package.json exports and Vanilla Extract CSS.",
  "version": "2.11.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "packages/ts-unused-exports"
  },
  "license": "MIT",
  "type": "module",
  "exports": "./src/ts-unused-exports.ts",
  "publishConfig": {
    "exports": {
      "types": "./dist/ts-unused-exports.d.ts",
      "import": "./dist/ts-unused-exports.js",
      "require": "./dist/ts-unused-exports.js"
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit true",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "unused": "node tools/unused.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@goatjs/node": "workspace:*",
    "ts-unused-exports": "^11.0.1"
  },
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^2.18.0",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "execa": "^9.6.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "*"
  }
}
