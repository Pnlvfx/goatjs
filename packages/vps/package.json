{
  "name": "@goatjs/vps",
  "description": "Utilities for deploying applications to VPS.",
  "version": "2.19.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "packages/vps"
  },
  "license": "MIT",
  "type": "module",
  "bin": "src/cli.ts",
  "exports": {
    ".": "./src/index.ts",
    "./plugins/*": "./src/plugins/*.ts",
    "./types/*": "./src/types/*.ts"
  },
  "publishConfig": {
    "bin": {
      "vps": "dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./plugins/*": {
        "types": "./dist/plugins/*.d.ts",
        "import": "./dist/plugins/*.js"
      },
      "./types/*": {
        "types": "./dist/types/*.d.ts",
        "import": "./dist/types/*.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "unused": "node tools/unused.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@goatjs/core": "workspace:*",
    "@goatjs/dbz": "workspace:*",
    "@goatjs/node": "workspace:*",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/storage": "workspace:*",
    "@types/cross-spawn": "^6.0.6",
    "adm-zip": "^0.5.17",
    "cross-spawn": "^7.0.6",
    "node-ssh": "^13.2.1",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@goatjs/node": "workspace:*",
    "@goatjs/node-monorepo-eslint": "^2.14.0",
    "@goatjs/ts-unused-exports": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}
