{
  "name": "@goatjs/storage",
  "description": "Persistent storage utilities for Node.js applications with support for files, stores, and logging.",
  "version": "2.11.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "packages/storage"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/storage.ts",
    "./logger": "./src/logger.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/storage.d.ts",
        "import": "./dist/storage.js",
        "require": "./dist/storage.js"
      },
      "./logger": {
        "types": "./dist/logger.d.ts",
        "import": "./dist/logger.js",
        "require": "./dist/logger.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit true",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "unused": "node tools/unused.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@goatjs/node": "workspace:*"
  },
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^2.18.0",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/ts-unused-exports": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "execa": "^9.6.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "*"
  }
}
