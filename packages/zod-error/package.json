{
  "name": "@goatjs/zod-error",
  "description": "Enhanced Zod error handling with custom error messages and global configuration.",
  "version": "1.80.0",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/goatjs.git",
    "directory": "packages/zod-error"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "exports": {
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js",
        "require": "./dist/*.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "test": "",
    "lint": "eslint",
    "build": "node tools/build.ts",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "unused": "node tools/unused.ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@goatjs/node": "workspace:*",
    "@goatjs/node-monorepo-eslint": "^2.1.0",
    "@goatjs/rimraf": "workspace:*",
    "@goatjs/ts-unused-exports": "workspace:*",
    "@goatjs/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "*"
  }
}
